# ==============================================================================
# Naver OpenAPI Configuration (REQUIRED)
# ==============================================================================
# Get your credentials from: https://developers.naver.com/
# 1. Create an application at https://developers.naver.com/apps/#/register
# 2. Enable "검색" (Search) API
# 3. Copy the Client ID and Client Secret below
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# ==============================================================================
# Database Configuration
# ==============================================================================
POSTGRES_HOST=postgres
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5432

# ==============================================================================
# Crawler Configuration
# ==============================================================================
# REQUIRED: 크롤링 검색 키워드 (예: 당근마켓, 카카오, 네이버)
SEARCH_KEYWORD=your_search_keyword_here
MAX_ARTICLES=50
MAX_PAGES=3  # Number of pages to crawl (10 articles per page)
SORT_ORDER=date  # 'date' or 'sim' (similarity/relevance)
START_DATE=  # Optional: YYYY-MM-DD format for date range filtering
END_DATE=  # Optional: YYYY-MM-DD format for date range filtering

# ==============================================================================
# Scheduler Configuration
# ==============================================================================
CRAWL_SCHEDULE=0 9 * * *  # Daily at 9 AM
RUN_ON_START=false  # Run crawler immediately on startup

# ==============================================================================
# Application Configuration
# ==============================================================================
LOG_LEVEL=INFO

# ==============================================================================
# LLM Configuration (자소서 자동화)
# ==============================================================================
# Required: Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: Override default model names
GEMINI_FLASH_MODEL=gemini-2.0-flash
GEMINI_PRO_MODEL=gemini-2.5-pro

# Optional: DART 사업보고서 API (기업 분석 강화)
DART_API_KEY=

# Optional: Firecrawl API (Naver News fallback)
FIRECRAWL_API_KEY=

# ==============================================================================
# Security Note:
# ==============================================================================
# 1. Copy this file to .env
# 2. Replace 'your_secure_password_here' with your actual database password
# 3. Replace 'your_naver_client_id_here' and 'your_naver_client_secret_here'
#    with your actual Naver API credentials
# 4. Never commit .env file to git

# Database Configuration
POSTGRES_HOST=postgres
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5432

# Crawler Configuration
SEARCH_KEYWORD=당근마켓
CRAWL_INTERVAL=3600  # seconds (1 hour)

# Naver News API Configuration
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# Scheduler Configuration
CRAWL_SCHEDULE=0 9 * * *  # Daily at 9 AM

# Application Configuration
LOG_LEVEL=INFO
MAX_ARTICLES=50

# Security Note:
# 1. Copy this file to .env
# 2. Replace 'your_secure_password_here' with your actual database password
# 3. Replace 'your_naver_client_id_here' and 'your_naver_client_secret_here' with your Naver API credentials
#    - Get them from: https://developers.naver.com/
# 4. Never commit .env file to git
